---
// src/components/Architecture.astro
const features = [
  {
    title: 'Write-Contention Buffering',
    description: 'Instead of hitting Postgres on every link click, reads are buffered in a Redis Hash via a non-blocking Go channel and flushed every 60s. This ensures a viral link receiving 10,000 clicks/min results in exactly 1 database write, protecting Postgres from write-locks.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'
  },
  {
    title: 'Read-Through Caching',
    description: 'Redis acts as the primary read layer. Cache misses gracefully fall back to Postgres and automatically populate Redis. Subsequent reads bypass the database entirely, protecting the primary data store during read spikes.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z'
  },
  {
    title: 'Single-Binary SPA Deployment',
    description: 'The Astro SPA is statically compiled and injected directly into the Go backend using //go:embed. It ships as a single, self-contained binary without needing a separate Nginx server, drastically simplifying CI/CD and infrastructure overhead.',
    icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4'
  },
  {
    title: 'Enterprise Observability',
    description: 'Fully instrumented with the OTel SDK. It provides explicit bucket histograms for exact latency percentiles (p95, p99) and custom resource collectors for connection pools, demonstrating operational maturity beyond basic HTTP logs.',
    icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'
  },
  {
    title: 'Collision-Free Short Codes',
    description: 'Uses the sqids-go library coupled with a Postgres SEQUENCE. This mathematically guarantees 100% collision-free codes natively, completely eliminating the need for expensive database collision checks or while-loop retries.',
    icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1'
  },
  {
    title: 'Graceful Shutdown & Cron',
    description: 'Internal context-aware cron scheduler manages purging. sync.WaitGroup worker lifecycles ensure that upon receiving a SIGTERM, all in-flight channel buffers are safely flushed to Postgres before exiting, guaranteeing zero data loss.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
  }
];
---

<section id="architecture" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-base font-semibold text-indigo-600 tracking-wide uppercase">Engineering Decisions & Architecture</h2>
      <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        A deep dive into system design
      </p>
      <p class="mt-4 max-w-2xl text-xl text-slate-500 mx-auto">
        Trade-offs, scalability patterns, and infrastructure choices that make our Go-based engine incredibly robust.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {features.map((feature) => (
        <div class="relative bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:shadow-lg transition duration-300">
          <div class="absolute top-8 left-8 bg-indigo-100 rounded-xl p-3">
            <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.icon} />
            </svg>
          </div>
          <div class="pl-16">
            <h3 class="text-xl font-bold text-slate-900 mb-2">{feature.title}</h3>
            <p class="text-slate-600 leading-relaxed">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>